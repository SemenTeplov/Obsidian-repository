{
	"nodes":[
		{"id":"d9b344d336ed2d89","type":"group","x":-380,"y":-160,"width":380,"height":920,"label":"Broker"},
		{"id":"abc1a087afba3621","type":"group","x":1385,"y":-431,"width":335,"height":351,"label":"Семантика доставки"},
		{"id":"c49574de4b8bb621","type":"group","x":-312,"y":-120,"width":205,"height":246,"label":"Topic 1"},
		{"id":"25bf7ff19a57b1bf","type":"group","x":-312,"y":180,"width":205,"height":246,"label":"Topic 1"},
		{"id":"44fd10561160cb6a","type":"group","x":-312,"y":480,"width":205,"height":246,"label":"Topic 1"},
		{"id":"13487f3034bc2d05","type":"group","x":219,"y":80,"width":181,"height":201,"label":"Group"},
		{"id":"98e3c9c13810937a","type":"text","text":"избранием лидеров партиций","x":853,"y":-1355,"width":354,"height":57},
		{"id":"1d11574668ba9905","type":"text","text":"изменениями в топологии кластера","x":853,"y":-1178,"width":386,"height":50},
		{"id":"0f403f43168cc2ef","type":"text","text":"репликацией данных","x":853,"y":-1258,"width":250,"height":60},
		{"id":"c116c49b59aea7f2","type":"text","text":"имеет фолловеров (Followers) — реплики данных на других брокерах","x":355,"y":-2146,"width":712,"height":68},
		{"id":"6863960c555e5784","type":"text","text":"если брокер не отправляет сигнал в течение заданного времени, ZooKeeper считает его недоступным","x":355,"y":-2006,"width":712,"height":86},
		{"id":"3d486688667bb4ec","type":"text","text":"Обнаружение сбоев (мониторинг состояния)","x":-20,"y":-1958,"width":344,"height":76},
		{"id":"4b94c3c05c1d477e","type":"text","text":"остальные брокеры получают уведомление о сбое и могут перераспределить нагрузку","x":355,"y":-1882,"width":712,"height":84},
		{"id":"f56fef2c20ab39af","type":"text","text":"все брокеры имеют актуальную информацию о состоянии кластера","x":397,"y":-1080,"width":706,"height":50},
		{"id":"5816b89597d5e4f2","type":"text","text":"реплики синхронизируются с лидером","x":397,"y":-1007,"width":456,"height":50},
		{"id":"9140e0c7f4e10bf0","type":"text","text":"клиенты получают корректные метаданные (например, адреса лидеров партиций)","x":397,"y":-945,"width":723,"height":105},
		{"id":"f9f5b4d64d9f94c7","type":"text","text":"Не более одного раза: сообщение может быть потеряно, но никогда не дублируется. Продюсер отправляет сообщение без подтверждения. Консьюмер автоматически коммитит офсет до обработки сообщения. Если консьюмер упадёт до обработки, сообщение будет потеряно. Этот вид доставки используется в системах где потеря данных не является критичным — например, метрики, логи).","x":2040,"y":-437,"width":452,"height":357},
		{"id":"ae6dbce726325cde","type":"text","text":"Не менее одного раза: сообщение никогда не теряется, но может быть дублировано. Продюсер включает подтверждения и повторные попытки. Консьюмер вручную коммитит офсет после обработки. В этом случае может возникнуть дублирование сообщений при повторной отправке или сбое. Эту гарантию доставки лучше использовать для систем, где потеря данных недопустима (платежи, заказы).","x":2040,"y":-880,"width":452,"height":380},
		{"id":"69fb25a8eb3fa031","type":"text","text":"Точно один раз: сообщение доставляется ровно один раз, даже при сбоях. Продюсер использует транзакции и идемпотентность. Консьюмер читает только зафиксированные транзакции. В этом случае мы нагружаем Kafka управлением транзакциями и из‑за этого у нас увеличивается время доставки сообщений. Подобную гарантию доставки рекомендуется использовать при построении обработки критичных операций где требуется обработка сообщения строго один раз.","x":2040,"y":-20,"width":452,"height":455},
		{"id":"f9d34535d9e35cd0","type":"text","text":"Отключение повтора отправки сообщения у producer","x":2625,"y":-435,"width":250,"height":116},
		{"id":"9de9b27ab154cb28","type":"text","text":"Включение автокомита у consumer","x":2625,"y":-221,"width":250,"height":133},
		{"id":"69dcaacd4a3e4f80","type":"text","text":"Настройка получения подтверждения и включение повторной отправки сообщения у producer","x":2625,"y":-911,"width":250,"height":221},
		{"id":"af7dfd17f6ffeb54","type":"text","text":"Включение ручного комита для consumer","x":2625,"y":-611,"width":250,"height":93},
		{"id":"bdac611e3dd4fdf8","type":"text","text":"Управление конфигурацией","x":-20,"y":-1718,"width":344,"height":60},
		{"id":"1a110f603216bd68","type":"text","text":"имеет лидера (Leader) — брокер, который обрабатывает все записи и чтения для этой партиции","x":355,"y":-2295,"width":712,"height":103},
		{"id":"db901e4afd49c56c","type":"text","text":"Управление лидерством и избрание лидера","x":-20,"y":-2238,"width":287,"height":92},
		{"id":"410b20018cfc42aa","type":"text","text":"Exactly once","x":1440,"y":-190,"width":195,"height":71},
		{"id":"f2b7169bdbd390fe","type":"text","text":"At least once","x":1440,"y":-390,"width":195,"height":71},
		{"id":"adaa619903b2dd0d","type":"text","text":"At most once","x":1440,"y":-290,"width":195,"height":71},
		{"id":"fabc0aa7f3bc6524","type":"text","text":"Включение идемпотентности и использование транзакций у producer","x":2625,"y":-20,"width":250,"height":243},
		{"id":"0725bf44bcb9f884","type":"text","text":"Установка уровня изоляции read commited у consumer","x":2625,"y":303,"width":250,"height":150},
		{"id":"a4c3a83abac38f3c","type":"text","text":"Координация контроллера кластера","x":-20,"y":-1458,"width":344,"height":80},
		{"id":"6a35b7b026f75a1a","type":"text","text":"переназначает контроллер в случае его сбоя","x":379,"y":-1438,"width":500,"height":60},
		{"id":"08be2ebe7ffaeeff","type":"text","text":"помогает контроллеру управлять","x":379,"y":-1258,"width":380,"height":60},
		{"id":"8b233e443b7bfb39","type":"text","text":"Обеспечение согласованности данных","x":-20,"y":-1000,"width":344,"height":85},
		{"id":"e3fdfb1d7cbac878","type":"text","text":"partition 1","x":-292,"y":-100,"width":165,"height":53},
		{"id":"33850a0ddb1a16d9","type":"text","text":"partition 2","x":-292,"y":-27,"width":165,"height":53},
		{"id":"a4ba7446c71bab50","type":"text","text":"partition 3","x":-292,"y":53,"width":165,"height":53},
		{"id":"292f0028e2a6eb55","type":"text","text":"Сообщение: ключ, значение, время и метаданные","x":-292,"y":-400,"width":240,"height":120},
		{"id":"6d5d6578f97dc28b","type":"text","text":"ZooKeeper — это распределённая служба координации для приложений","x":-580,"y":-1848,"width":280,"height":160},
		{"id":"969caa9432707ef1","type":"text","text":"настройки брокеров (например, лимиты на размер сообщений)","x":379,"y":-1778,"width":688,"height":60},
		{"id":"3a97034f2fa53864","type":"text","text":"параметры топиков (количество партиций, фактор репликации)","x":379,"y":-1688,"width":688,"height":60},
		{"id":"c4bcbb88bc9434d6","type":"text","text":"Это позволяет изменять настройки без перезапуска брокеров.","x":1207,"y":-1634,"width":380,"height":82},
		{"id":"affbb6e623eea65f","type":"text","text":"политики хранения данных","x":379,"y":-1612,"width":332,"height":60},
		{"id":"be5eadffb4816e41","type":"text","text":"выбирает контроллер при запуске кластера","x":379,"y":-1518,"width":500,"height":50},
		{"id":"033b118ffb7e7de5","type":"text","text":"partition 1","x":-292,"y":200,"width":165,"height":53},
		{"id":"511913cce3a7119a","type":"text","text":"partition 3","x":-292,"y":653,"width":165,"height":53},
		{"id":"2122d05657114edf","type":"text","text":"partition 1","x":-292,"y":499,"width":165,"height":53},
		{"id":"f3056611aa8239b6","type":"text","text":"partition 2","x":-292,"y":280,"width":165,"height":53},
		{"id":"b623489c0b89f92f","type":"text","text":"о брокерах Kafka (их ID и статусе)","x":351,"y":-2670,"width":376,"height":60},
		{"id":"6526c51a0a14c505","type":"text","text":"о топиках и их разделах (партициях)","x":351,"y":-2575,"width":396,"height":60},
		{"id":"6a8c68b49bc853e7","type":"text","text":"Это позволяет брокерам узнавать о состоянии друг друга и определять, где находятся нужные данные.","x":1087,"y":-2573,"width":420,"height":134},
		{"id":"858fd575138a9982","type":"text","text":"о потребителях (консьюмерах) и их группах","x":353,"y":-2486,"width":454,"height":60},
		{"id":"d4680d85670c1b5e","type":"text","text":"о расположении данных (где какие партиции находятся)","x":353,"y":-2398,"width":594,"height":60},
		{"id":"bf21fa16901a6336","type":"text","text":"Хранение метаданных","x":-20,"y":-2534,"width":267,"height":56},
