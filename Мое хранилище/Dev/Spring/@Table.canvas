	"nodes":[
		{"id":"519753373f549f6d","x":-840,"y":-551,"width":331,"height":617,"type":"group","label":"Атрибуты"},
		{"id":"c3a952a3496d94a7","x":60,"y":-500,"width":359,"height":514,"type":"group","label":"Цели"},
		{"id":"fe384375d2e08fd1","x":-280,"y":-280,"width":130,"height":62,"type":"text","text":"@Table"},
		{"id":"e68b4b4349f51c4d","x":-445,"y":-640,"width":460,"height":284,"type":"text","text":"Аннотация @Table используется для настройки сопоставления класса сущностей с таблицей базы данных. По умолчанию JPA использует имя класса в качестве имени таблицы, но с помощью @Table разработчики могут явно указывать имена таблиц, схемы, каталоги и уникальные ограничения."},
		{"id":"62131bfe171844be","x":80,"y":-480,"width":319,"height":120,"type":"text","text":"Имя таблицы в базе данных отличается от имени класса сущности"},
		{"id":"6d0979ff05e10b11","x":80,"y":-340,"width":319,"height":160,"type":"text","text":"Для организации базы данных необходимо определить схему или каталог"},
		{"id":"85a95273918d1666","x":80,"y":-160,"width":319,"height":154,"type":"text","text":"Необходимо обеспечить соблюдение уникальных ограничений для определенных столбцов"},
		{"id":"90323f1977817f01","x":-820,"y":-531,"width":291,"height":155,"type":"text","text":"name: указывает имя таблицы в базе данных (по умолчанию: имя класса сущности)"},
		{"id":"a90e616e02a5b6e9","x":-820,"y":-362,"width":291,"height":96,"type":"text","text":"catalog: определяет имя каталога базы данных"},
		{"id":"04c49f4a8662e9b9","x":-820,"y":-252,"width":291,"height":86,"type":"text","text":"schema: определяет имя схемы для таблицы"},
		{"id":"907d2d1937e0a077","x":-820,"y":-147,"width":291,"height":193,"type":"text","text":"uniqueConstraints: обеспечивает соблюдение уникальных ограничений для одного или нескольких столбцов"}
	],
